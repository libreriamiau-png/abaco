<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>📥 Importar — Libros Bosch</title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    :root {
      --negro:#1a1a1a; --oscuro:#2c2c2c; --medio:#555; --muted:#888;
      --borde:#ccc; --fondo:#f5f5f5; --blanco:#fff;
      --dorado:#c8640a; --dorado-l:#e07010; --verde:#2d6a4f; --rojo:#b33a2a;
    }
    body { font-family:Arial,Helvetica,sans-serif; background:var(--fondo); color:var(--negro); padding:20px; font-size:15px; line-height:1.5; }
    .header { background:var(--negro); color:white; padding:20px 32px; margin-bottom:24px; border-bottom:3px solid var(--dorado); }
    .header h1 { font-size:1.6rem; font-weight:700; margin-bottom:2px; }
    .header p { font-size:.9rem; opacity:.7; }
    .header-nav { display:flex; gap:20px; margin-top:12px; }
    .header-nav a { color:white; opacity:.6; font-size:.85rem; text-transform:uppercase; text-decoration:none; padding:4px 0; border-bottom:2px solid transparent; transition:all .2s; }
    .header-nav a:hover { opacity:1; border-bottom-color:var(--dorado); }
    .card { background:white; padding:24px; border:1px solid var(--borde); margin-bottom:20px; }
    .card-title { font-size:1rem; font-weight:700; margin-bottom:18px; display:flex; align-items:center; gap:8px; border-bottom:2px solid var(--borde); padding-bottom:12px; text-transform:uppercase; }
    .zona-drop { border:2px dashed var(--borde); padding:48px 24px; text-align:center; cursor:pointer; transition:all .2s; background:var(--fondo); }
    .zona-drop:hover, .zona-drop.drag { border-color:var(--dorado); background:#fff8f0; }
    .zona-drop .icono { font-size:3rem; margin-bottom:12px; }
    .zona-drop .texto { font-size:1.1rem; font-weight:700; margin-bottom:6px; }
    .zona-drop .sub { font-size:.88rem; color:var(--muted); }
    #fileInput { display:none; }
    .stats-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-bottom:20px; }
    .stat { background:white; padding:16px; border:1px solid var(--borde); border-top:3px solid var(--dorado); text-align:center; }
    .stat .val { font-size:2rem; font-weight:700; }
    .stat .lab { font-size:.75rem; text-transform:uppercase; color:var(--muted); margin-top:4px; }
    .stat.verde { border-top-color:var(--verde); }
    .stat.rojo  { border-top-color:var(--rojo); }
    .btn { padding:9px 20px; border:1px solid var(--borde); font-size:.9rem; font-weight:700; cursor:pointer; transition:all .15s; display:inline-flex; align-items:center; gap:6px; font-family:Arial,sans-serif; background:white; color:var(--negro); }
    .btn:hover { background:var(--fondo); }
    .btn-primary { background:var(--dorado); color:white; border-color:var(--dorado); }
    .btn-primary:hover { background:var(--dorado-l); }
    .btn:disabled { opacity:.4; cursor:not-allowed; }
    .tabla-wrap { overflow-x:auto; border:1px solid var(--borde); max-height:420px; overflow-y:auto; }
    table { width:100%; border-collapse:collapse; font-size:.82rem; }
    th { text-align:left; padding:8px 10px; background:var(--negro); color:white; font-weight:700; font-size:.72rem; text-transform:uppercase; white-space:nowrap; position:sticky; top:0; z-index:1; }
    td { padding:7px 10px; border-bottom:1px solid #eee; vertical-align:top; }
    tr:hover td { background:#fff8f0; }
    .td-stock { font-weight:700; color:var(--dorado); }
    .td-warn { background:#fff3e0 !important; }
    .td-ok   { background:#e8f5e9 !important; }
    .td-err  { background:#fce4e4 !important; }
    .progreso-wrap { margin:16px 0; }
    .progreso-barra { height:8px; background:#eee; border-radius:4px; overflow:hidden; }
    .progreso-fill { height:100%; background:var(--dorado); transition:width .2s; width:0%; }
    .progreso-texto { font-size:.85rem; color:var(--muted); margin-top:6px; }
    .aviso { padding:12px 16px; border-left:3px solid var(--dorado); background:#fff8f0; font-size:.88rem; margin-bottom:16px; }
    .aviso.verde { border-left-color:var(--verde); background:#e8f5e9; }
    .aviso.rojo  { border-left-color:var(--rojo);  background:#fce4e4; }
    .toast { position:fixed; bottom:20px; left:50%; transform:translateX(-50%) translateY(80px); background:var(--negro); color:white; padding:10px 22px; font-size:.9rem; font-weight:700; z-index:9999; border-bottom:2px solid var(--dorado); transition:transform .25s; }
    .toast.visible { transform:translateX(-50%) translateY(0); }
    .toast.error { border-bottom-color:var(--rojo); }
    .flex { display:flex; gap:10px; align-items:center; flex-wrap:wrap; }
    .mt { margin-top:16px; }
    .oculto { display:none; }
  </style>
</head>
<body>
<div class="header">
  <h1>📥 Importar fondos — Libros Bosch</h1>
  <p>Migración desde Booksell · CSV a Supabase</p>
  <nav class="header-nav">
    <a href="INVENTARIO.html">Inventario</a>
    <a href="CLIENTES.html">Clientes</a>
  </nav>
</div>

<div class="card" id="paso1">
  <div class="card-title">📂 Paso 1 — Selecciona el CSV de Booksell</div>
  <div class="aviso">Exporta desde Booksell en formato CSV sin cabecera. La codificación Windows-1252 se lee automáticamente.</div>
  <div class="zona-drop" id="zonaDrop" onclick="document.getElementById('fileInput').click()">
    <div class="icono">📄</div>
    <div class="texto">Haz clic o arrastra aquí el fichero CSV</div>
    <div class="sub">Formato exportación Booksell</div>
  </div>
  <input type="file" id="fileInput" accept=".csv,.CSV">
</div>

<div class="card oculto" id="paso2">
  <div class="card-title">🔍 Paso 2 — Previsualización y revisión</div>
  <div class="stats-grid">
    <div class="stat"><div class="val" id="stTotal">0</div><div class="lab">Registros leídos</div></div>
    <div class="stat verde"><div class="val" id="stOk">0</div><div class="lab">Listos para importar</div></div>
    <div class="stat" style="border-top-color:#f0a000;"><div class="val" id="stWarn">0</div><div class="lab">Con advertencias</div></div>
    <div class="stat rojo"><div class="val" id="stErr">0</div><div class="lab">Con errores</div></div>
  </div>
  <div class="aviso" id="avisoGeneral"></div>
  <div class="tabla-wrap">
    <table>
      <thead><tr>
        <th>Stock</th><th>Autor</th><th>Título</th><th>Lugar</th><th>Editorial</th>
        <th>Año</th><th>Precio</th><th>ISBN</th><th>Encuad. Abe</th><th>Estado</th><th>Materia</th><th></th>
      </tr></thead>
      <tbody id="tbodyPrev"></tbody>
    </table>
  </div>
  <div class="flex mt">
    <button class="btn btn-primary" id="btnImportar" onclick="iniciarImportacion()">📥 Importar a Supabase</button>
    <button class="btn" onclick="reiniciar()">↺ Cargar otro archivo</button>
    <span style="font-size:.85rem;color:var(--muted);">No sobreescribe registros con el mismo nº de stock.</span>
  </div>
</div>

<div class="card oculto" id="paso3">
  <div class="card-title">⏳ Paso 3 — Importando...</div>
  <div class="progreso-wrap">
    <div class="progreso-barra"><div class="progreso-fill" id="progresoFill"></div></div>
    <div class="progreso-texto" id="progresoTexto">Preparando...</div>
  </div>
  <div id="resultadoFinal" class="oculto">
    <div class="aviso verde" id="mensajeFinal"></div>
    <div class="flex mt">
      <a href="INVENTARIO.html" class="btn btn-primary">📚 Ir al inventario</a>
      <button class="btn" onclick="reiniciar()">📥 Importar otro archivo</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
const SUPABASE_URL  = 'https://ohlrldyobyxurnkwheli.supabase.co';
const SUPABASE_ANON = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im9obHJsZHlvYnl4dXJua3doZWxpIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQwMjEwNTEsImV4cCI6MjA4OTU5NzA1MX0.GcK2rk3gyPf0MeaoMgnQeuUfRMwEgr1SbUw6Md6AWCU';
const API = SUPABASE_URL + '/rest/v1';
const HEADERS = { 'apikey':SUPABASE_ANON, 'Authorization':'Bearer '+SUPABASE_ANON, 'Content-Type':'application/json', 'Prefer':'return=representation' };

let registrosParsed = [];

const zona = document.getElementById('zonaDrop');
zona.addEventListener('dragover', e => { e.preventDefault(); zona.classList.add('drag'); });
zona.addEventListener('dragleave', () => zona.classList.remove('drag'));
zona.addEventListener('drop', e => { e.preventDefault(); zona.classList.remove('drag'); const f=e.dataTransfer.files[0]; if(f) procesarArchivo(f); });
document.getElementById('fileInput').addEventListener('change', e => { if(e.target.files[0]) procesarArchivo(e.target.files[0]); });

function procesarArchivo(file) {
  const reader = new FileReader();
  reader.onload = e => { const filas=parseCSV(e.target.result); registrosParsed=filas.map(mapearFila).filter(Boolean); mostrarPrevisualizacion(); };
  reader.readAsText(file, 'windows-1252');
}

function parseCSV(texto) {
  const filas=[];
  for (const linea of texto.split(/\r?\n/)) {
    if (!linea.trim()) continue;
    const cols=parsearLinea(linea);
    if (cols.length>=8) filas.push(cols);
  }
  return filas;
}

function parsearLinea(linea) {
  const cols=[]; let actual='', enComillas=false;
  for (let i=0;i<linea.length;i++) {
    const c=linea[i];
    if (c==='"') { if(enComillas&&linea[i+1]==='"'){actual+='"';i++;} else enComillas=!enComillas; }
    else if (c===','&&!enComillas) { cols.push(actual.trim()); actual=''; }
    else actual+=c;
  }
  cols.push(actual.trim());
  return cols;
}

function mapearFila(cols) {
  const stockNo=parseInt(cols[0]);
  if (!stockNo) return null;
  const lugarEd=(cols[6]||'').replace(/,$/,'').trim();
  let lugar='',editorial='';
  const sep=lugarEd.indexOf(':');
  if (sep!==-1) { lugar=lugarEd.slice(0,sep).trim(); editorial=lugarEd.slice(sep+1).trim(); }
  else editorial=lugarEd;
  const precioRaw=(cols[8]||'').replace(/[^\d.,]/g,'').replace(',','.').trim();
  const precio=parseFloat(precioRaw)||null;
  const encAbeRaw=(cols[10]||'').trim();
  let encAbe='';
  if (/tapa dura/i.test(encAbeRaw)) encAbe='Tapa dura';
  else if (/tapa blanda/i.test(encAbeRaw)||/r[uú]stica/i.test(encAbeRaw)) encAbe='Tapa blanda';
  const estadoMap={'muy bien':'Muy bien','bien':'Bien','como nuevo':'Como nuevo','aceptable':'Aceptable','pobre':'Pobre','nuevo':'Nuevo'};
  const estadoRaw=(cols[11]||'').trim();
  const estado=estadoMap[estadoRaw.toLowerCase()]||estadoRaw||'Muy bien';
  const tipoMap={'libros':'Libro','libro':'Libro','fotografía':'Fotografía','grabado':'Grabado','postal':'Postal','mapa':'Mapa','manuscrito':'Manuscrito','revista':'Revista'};
  const tipo=tipoMap[((cols[1]||'Libro').trim()).toLowerCase()]||'Libro';
  const isbn=(cols[9]||'').replace(/[^0-9X-]/gi,'').trim()||null;
  const warnings=[];
  if (!cols[2]?.trim()) warnings.push('Sin autor');
  if (!precio) warnings.push('Sin precio');
  return {
    stock_no:stockNo, tipo,
    autor:(cols[2]||'').trim()||null,
    titulo:(cols[3]||'').trim()||null,
    descripcion:(cols[5]||'').trim()||null,
    lugar:lugar||null, editorial:editorial||null,
    fecha:(cols[7]||'').trim()||null,
    precio, isbn,
    encuadernacion_abebooks:encAbe||null,
    estado,
    materia:(cols[12]||'').trim()||null,
    materia2:(cols[13]||'').trim()||null,
    cantidad:1,
    _warnings:warnings,
    _error:!(cols[3]?.trim())
  };
}

function mostrarPrevisualizacion() {
  document.getElementById('paso1').classList.add('oculto');
  document.getElementById('paso2').classList.remove('oculto');
  const total=registrosParsed.length;
  const errores=registrosParsed.filter(r=>r._error).length;
  const warns=registrosParsed.filter(r=>!r._error&&r._warnings.length).length;
  const ok=total-errores-warns;
  document.getElementById('stTotal').textContent=total;
  document.getElementById('stOk').textContent=ok;
  document.getElementById('stWarn').textContent=warns;
  document.getElementById('stErr').textContent=errores;
  const aviso=document.getElementById('avisoGeneral');
  if (errores>0) { aviso.className='aviso rojo'; aviso.textContent=errores+' registro(s) sin título no se importarán. El resto sí.'; }
  else if (warns>0) { aviso.className='aviso'; aviso.textContent=warns+' registro(s) con campos incompletos (sin precio o sin autor). Se importarán igualmente — puedes completarlos después.'; }
  else { aviso.className='aviso verde'; aviso.textContent='✓ Todos los registros están completos y listos para importar.'; }
  const tbody=document.getElementById('tbodyPrev');
  tbody.innerHTML=registrosParsed.slice(0,200).map(r=>{
    const cls=r._error?'td-err':r._warnings.length?'td-warn':'td-ok';
    const w=r._warnings.length?'<br><small style="color:var(--muted)">'+r._warnings.join(', ')+'</small>':'';
    return '<tr><td class="td-stock '+cls+'">'+r.stock_no+'</td><td>'+(r.autor||'—')+'</td><td>'+tr(r.titulo,45)+w+'</td><td>'+(r.lugar||'—')+'</td><td>'+tr(r.editorial,25)+'</td><td>'+(r.fecha||'—')+'</td><td>'+(r.precio!=null?r.precio+'€':'—')+'</td><td style="font-size:.78rem;">'+(r.isbn||'—')+'</td><td>'+(r.encuadernacion_abebooks||'—')+'</td><td>'+(r.estado||'—')+'</td><td>'+tr(r.materia,20)+'</td><td class="'+cls+'" style="font-size:.75rem;font-weight:700;">'+(r._error?'❌':r._warnings.length?'⚠️':'✓')+'</td></tr>';
  }).join('');
  if (registrosParsed.length>200) tbody.innerHTML+='<tr><td colspan="12" style="text-align:center;padding:12px;color:var(--muted);font-style:italic;">... y '+(registrosParsed.length-200)+' registros más (se importarán todos)</td></tr>';
}

function tr(s,n){if(!s)return'—';return s.length>n?s.slice(0,n)+'…':s;}

async function iniciarImportacion() {
  const validos=registrosParsed.filter(r=>!r._error&&r.titulo);
  if (!validos.length) return toast('No hay registros válidos',true);
  if (!confirm('¿Importar '+validos.length+' libros a Supabase?\n\nNo sobreescribirá registros con el mismo nº de stock.')) return;
  document.getElementById('paso2').classList.add('oculto');
  document.getElementById('paso3').classList.remove('oculto');
  document.getElementById('btnImportar').disabled=true;
  const fill=document.getElementById('progresoFill');
  const ptxt=document.getElementById('progresoTexto');
  ptxt.textContent='Verificando registros existentes...';
  let stocksExist=new Set();
  try { const ex=await apiFetch('/inventario?select=stock_no'); stocksExist=new Set((ex||[]).map(r=>r.stock_no)); } catch(e){}
  const nuevos=validos.filter(r=>!stocksExist.has(r.stock_no));
  const saltados=validos.length-nuevos.length;
  if (!nuevos.length) { mostrarResultado(0,saltados,0); return; }
  const limpiar=r=>{const {_warnings,_error,...d}=r;return d;};
  const LOTE=100; let importados=0,errores=0;
  for (let i=0;i<nuevos.length;i+=LOTE) {
    const lote=nuevos.slice(i,i+LOTE).map(limpiar);
    try { await apiFetch('/inventario',{method:'POST',body:JSON.stringify(lote)}); importados+=lote.length; }
    catch(e) { for (const reg of lote){try{await apiFetch('/inventario',{method:'POST',body:JSON.stringify(reg)});importados++;}catch{errores++;}} }
    fill.style.width=Math.min(Math.round(((i+LOTE)/nuevos.length)*100),100)+'%';
    ptxt.textContent='Importando... '+Math.min(i+LOTE,nuevos.length)+' de '+nuevos.length;
    await new Promise(r=>setTimeout(r,50));
  }
  mostrarResultado(importados,saltados,errores);
}

function mostrarResultado(importados,saltados,errores) {
  document.querySelector('.progreso-wrap').style.display='none';
  const div=document.getElementById('resultadoFinal'); div.classList.remove('oculto');
  const msg=document.getElementById('mensajeFinal');
  msg.className=errores>0?'aviso':'aviso verde';
  msg.innerHTML='✓ Importación completada<br><br><strong>'+importados+'</strong> libros importados correctamente.<br>'+(saltados?'<strong>'+saltados+'</strong> omitidos (ya existían con ese nº de stock).<br>':'')+(errores?'<strong>'+errores+'</strong> con error al guardar.':'');
}

function reiniciar() {
  registrosParsed=[];
  document.getElementById('fileInput').value='';
  document.getElementById('paso1').classList.remove('oculto');
  document.getElementById('paso2').classList.add('oculto');
  document.getElementById('paso3').classList.add('oculto');
  document.getElementById('resultadoFinal').classList.add('oculto');
  document.getElementById('progresoFill').style.width='0%';
  document.getElementById('btnImportar').disabled=false;
}

async function apiFetch(endpoint,opts={}) {
  const res=await fetch(API+endpoint,{headers:HEADERS,...opts});
  if (!res.ok) throw new Error(await res.text());
  const ct=res.headers.get('content-type')||'';
  if (ct.includes('json')&&res.status!==204) return res.json();
  return null;
}

function toast(msg,error=false) {
  const el=document.getElementById('toast');
  el.textContent=msg; el.className='toast'+(error?' error':'');
  el.classList.add('visible'); setTimeout(()=>el.classList.remove('visible'),3000);
}
</script>
</body>
</html>
